{
  "name": "thtns-blog",
  "version": "1.0.0",
  "description": "The source of thtns's personal blog.",
  "private": true,
  "scripts": {
    "build": "hexo clean && hexo generate",
    "build:github": "hexo clean && hexo generate --config _config.yml,_config.github.yml",
    "build:server": "hexo clean && hexo generate --config _config.yml,_config.server.yml",
    "clean": "hexo clean",
    "dev": "hexo server --draft",
    "new": "hexo new",
    "new:draft": "hexo new draft",
    "publish": "hexo publish",
    "server": "hexo server"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "hexo": {
    "version": "8.1.2"
  },
  "dependencies": {
    "hexo": "^8.1.2",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "^4.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-searchdb": "^1.5.0",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-next": "^8.28.0",
    "hexo-word-counter": "^0.3.0-rc.1"
  }
}
